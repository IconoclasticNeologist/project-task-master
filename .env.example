# Supabase — browser (client) credentials. Safe to expose; protected by RLS.
# Copy to .env.local (gitignored via *.local) and fill with YOUR project's values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Supabase Edge Function secrets (set via `supabase secrets set ...`, NOT in
# this repo and NOT in .env.local). Listed here for discoverability only.
# ---------------------------------------------------------------------------
#
# advocate-voice-token requires:
#   GEMINI_API_KEY                 # raw Google Generative Language API key.
#                                   # Never sent to the browser. Used only to
#                                   # mint short-lived ephemeral tokens.
#   DAILY_VOICE_SESSION_CAP=200    # optional. Hard daily ceiling on voice
#                                   # sessions across all users. Default 200.
#
# Supabase auto-provides SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY to edge
# functions; no action needed.
#
# advocate-avatar-session (the Witness Stand practice person) requires:
#   LIVEAVATAR_API_KEY             # HeyGen LiveAvatar API key (app.liveavatar.com
#                                   # → Developers). Never sent to the browser.
#   LIVEAVATAR_LLM_CONFIG_ID       # llm_configuration_id pointing at the
#                                   # advocate-defense-llm shim (DEPLOY.md §3b).
#                                   # Without it the function refuses (503) and
#                                   # the app falls back to voice-only practice.
#   LIVEAVATAR_AVATAR_ID=          # optional. Avatar to use; defaults to the
#                                   # LiveAvatar public demo avatar.
#   LIVEAVATAR_SANDBOX=true        # optional. Free watermarked sessions for
#                                   # rehearsal; unset for the judged demo.
#
# advocate-defense-llm (the practice person's RAG-locked brain) requires:
#   GEMINI_API_KEY                 # same key as above.
#   LIVEAVATAR_SHIM_KEY            # shared bearer secret LiveAvatar uses to
#                                   # call the shim (DEPLOY.md §3b step 0/1).
#
# ---------------------------------------------------------------------------
# Build-time flags (Vite env — set in the DEPLOY environment, not per-user)
# ---------------------------------------------------------------------------
# VITE_DEMO_TOOLS=true            # shows the "Load an example (demo)" presenter
#                                  # button on Home. Set for the judged demo
#                                  # build; leave unset anywhere real people land.
